{
  "uid": "long-run-baseline-vs-native",
  "title": "Long Run Baseline vs Native",
  "schemaVersion": 40,
  "version": 1,
  "refresh": "5s",
  "timezone": "browser",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "tags": [
    "baseline",
    "native-image",
    "steady-state",
    "long-run"
  ],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Startup Time",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 5},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "max by (mode) (max_over_time(app_startup_time_ms{app=\"gateway-demo\",jdk=\"25\",mode=~\"baseline|native\"}[$__range]))",
          "instant": true
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "orientation": "horizontal", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto"}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Dependency Startup",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 5},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "max by (mode) (max_over_time(app_dependency_total_startup_ms{app=\"gateway-demo\",jdk=\"25\",mode=~\"baseline|native\"}[$__range]))",
          "instant": true
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "orientation": "horizontal", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto"}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Throughput",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 5},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (mode) (rate(http_server_requests_seconds_count{app=\"gateway-demo\",jdk=\"25\",mode=~\"baseline|native\"}[$__rate_interval]))",
          "legendFormat": "{{mode}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "none"}}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "HTTP Error Rate",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 5},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (mode) (rate(http_server_requests_seconds_count{app=\"gateway-demo\",jdk=\"25\",mode=~\"baseline|native\",status!~\"2..\"}[$__rate_interval])) / clamp_min(sum by (mode) (rate(http_server_requests_seconds_count{app=\"gateway-demo\",jdk=\"25\",mode=~\"baseline|native\"}[$__rate_interval])), 0.001)",
          "legendFormat": "{{mode}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "none"}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Latency p95",
      "gridPos": {"x": 0, "y": 5, "w": 8, "h": 7},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (mode, le) (rate(http_server_requests_seconds_bucket{app=\"gateway-demo\",jdk=\"25\",mode=~\"baseline|native\"}[$__rate_interval])))",
          "legendFormat": "{{mode}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "none"}}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Latency p99",
      "gridPos": {"x": 8, "y": 5, "w": 8, "h": 7},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (mode, le) (rate(http_server_requests_seconds_bucket{app=\"gateway-demo\",jdk=\"25\",mode=~\"baseline|native\"}[$__rate_interval])))",
          "legendFormat": "{{mode}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "none"}}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Average Latency",
      "gridPos": {"x": 16, "y": 5, "w": 8, "h": 7},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (mode) (rate(http_server_requests_seconds_sum{app=\"gateway-demo\",jdk=\"25\",mode=~\"baseline|native\"}[$__rate_interval])) / clamp_min(sum by (mode) (rate(http_server_requests_seconds_count{app=\"gateway-demo\",jdk=\"25\",mode=~\"baseline|native\"}[$__rate_interval])), 0.001)",
          "legendFormat": "{{mode}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "none"}}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "CPU Usage",
      "gridPos": {"x": 0, "y": 12, "w": 8, "h": 7},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "max by (mode) (process_cpu_usage{app=\"gateway-demo\",jdk=\"25\",mode=~\"baseline|native\"})",
          "legendFormat": "{{mode}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "none"}}
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "JVM Memory Used",
      "gridPos": {"x": 8, "y": 12, "w": 8, "h": 7},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (mode) (jvm_memory_used_bytes{app=\"gateway-demo\",jdk=\"25\",mode=~\"baseline|native\",area=~\"heap|nonheap\"})",
          "legendFormat": "{{mode}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "bytes", "min": 0}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "none"}}
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Heap and Non-Heap",
      "gridPos": {"x": 16, "y": 12, "w": 8, "h": 7},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (mode, area) (jvm_memory_used_bytes{app=\"gateway-demo\",jdk=\"25\",mode=~\"baseline|native\",area=~\"heap|nonheap\"})",
          "legendFormat": "{{mode}} {{area}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "bytes", "min": 0}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "none"}}
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "GC Pause Rate",
      "gridPos": {"x": 0, "y": 19, "w": 8, "h": 7},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (mode) (rate(jvm_gc_pause_seconds_sum{app=\"gateway-demo\",jdk=\"25\",mode=~\"baseline|native\"}[$__rate_interval]))",
          "legendFormat": "{{mode}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "none"}}
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "GC Pause Count",
      "gridPos": {"x": 8, "y": 19, "w": 8, "h": 7},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (mode) (rate(jvm_gc_pause_seconds_count{app=\"gateway-demo\",jdk=\"25\",mode=~\"baseline|native\"}[$__rate_interval]))",
          "legendFormat": "{{mode}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops", "min": 0}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "none"}}
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Live Threads",
      "gridPos": {"x": 16, "y": 19, "w": 8, "h": 7},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "max by (mode) (jvm_threads_live_threads{app=\"gateway-demo\",jdk=\"25\",mode=~\"baseline|native\"})",
          "legendFormat": "{{mode}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short", "min": 0}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "none"}}
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Dependency Startup Breakdown",
      "gridPos": {"x": 0, "y": 26, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "max by (mode) (app_dependency_postgres_startup_ms{app=\"gateway-demo\",jdk=\"25\",mode=~\"baseline|native\"})",
          "legendFormat": "{{mode}} postgres"
        },
        {
          "refId": "B",
          "expr": "max by (mode) (app_dependency_redis_startup_ms{app=\"gateway-demo\",jdk=\"25\",mode=~\"baseline|native\"})",
          "legendFormat": "{{mode}} redis"
        },
        {
          "refId": "C",
          "expr": "max by (mode) (app_dependency_kafka_startup_ms{app=\"gateway-demo\",jdk=\"25\",mode=~\"baseline|native\"})",
          "legendFormat": "{{mode}} kafka"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms", "min": 0}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "none"}}
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Requests by Endpoint",
      "gridPos": {"x": 12, "y": 26, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (mode, uri) (rate(http_server_requests_seconds_count{app=\"gateway-demo\",jdk=\"25\",mode=~\"baseline|native\",uri!=\"UNKNOWN\"}[$__rate_interval]))",
          "legendFormat": "{{mode}} {{uri}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "min": 0}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "none"}}
    },
    {
      "id": 16,
      "type": "table",
      "title": "Current Comparison Snapshot",
      "gridPos": {"x": 0, "y": 33, "w": 24, "h": 8},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (mode) (jvm_memory_used_bytes{app=\"gateway-demo\",jdk=\"25\",mode=~\"baseline|native\",area=~\"heap|nonheap\"})",
          "instant": true,
          "format": "table",
          "legendFormat": "JVM memory bytes"
        },
        {
          "refId": "B",
          "expr": "max by (mode) (process_cpu_usage{app=\"gateway-demo\",jdk=\"25\",mode=~\"baseline|native\"})",
          "instant": true,
          "format": "table",
          "legendFormat": "CPU"
        },
        {
          "refId": "C",
          "expr": "sum by (mode) (rate(http_server_requests_seconds_count{app=\"gateway-demo\",jdk=\"25\",mode=~\"baseline|native\"}[1m]))",
          "instant": true,
          "format": "table",
          "legendFormat": "RPS"
        },
        {
          "refId": "D",
          "expr": "histogram_quantile(0.95, sum by (mode, le) (rate(http_server_requests_seconds_bucket{app=\"gateway-demo\",jdk=\"25\",mode=~\"baseline|native\"}[1m])))",
          "instant": true,
          "format": "table",
          "legendFormat": "p95"
        },
        {
          "refId": "E",
          "expr": "histogram_quantile(0.99, sum by (mode, le) (rate(http_server_requests_seconds_bucket{app=\"gateway-demo\",jdk=\"25\",mode=~\"baseline|native\"}[1m])))",
          "instant": true,
          "format": "table",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {"defaults": {}, "overrides": []},
      "options": {"showHeader": true, "cellHeight": "sm", "footer": {"show": false, "reducer": ["sum"], "countRows": false, "fields": ""}}
    }
  ]
}
